# Server
PORT=8000
NODE_ENV=development

# MongoDB (local Compass connection)
MONGODB_URI=mongodb://127.0.0.1:27017/visionvoice

# CORS — your Vite frontend origin
CLIENT_ORIGIN=http://localhost:5173

# OCR languages (tesseract codes). eng+tam covers English & Tamil.
OCR_LANGS=eng+tam

# FREE cloud OCR (no credit card). Primary OCR engine — robust to blur/noise/angles.
# 'helloworld' is a rate-limited public demo key. Get your own free key (instant, email
# only) at https://ocr.space/ocrapi/freekey for 25,000 scans/month.
OCR_SPACE_API_KEY=helloworld

# ===== FREE AI for ALL smart features (no credit card) — MOST IMPORTANT KEY =====
# Google Gemini powers OCR, object/scene, currency, medicine, outfit AND the chatbot,
# and handles blurry / noisy / low-clarity photos. Get a FREE key at:
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI key. When set, powers ADVANCED GPT-4o VISION for OCR, object/scene,
# currency, medicine & color detection (near-perfect), PLUS the Voice Companion.
# If blank, the app falls back to local open-source models (Tesseract/TensorFlow).
OPENAI_API_KEY=
# gpt-4o = most accurate vision (best for blurry/tiny text). gpt-4o-mini = faster/cheaper.
OPENAI_MODEL=gpt-4o

# ===== Emergency SOS — REAL SMS sent directly to the contact, nothing opens on your phone =====
# Provider priority: Twilio > Fast2SMS > TextBelt. Set ONE of them.
# Option A (BEST for India): Fast2SMS — instant SMS to Indian numbers, free signup credits.
#   Key at https://www.fast2sms.com (Dashboard > Dev API).
FAST2SMS_API_KEY=
# Option B: TextBelt — global. 'textbelt' = 1 free SMS/day (testing only).
TEXTBELT_KEY=textbelt

# Option B: Twilio. If these are set, Twilio is used instead. If all blank, alerts are simulated.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
